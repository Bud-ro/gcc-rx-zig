+char *getBuffer(const char *path)
+{
+  long size;
+  char *buffer = 0;
+  FILE *file = fopen(path, "rb");
+  if(file == NULL)
+  {
+    return NULL;
+  }
+  if(fseek(file, 0L, SEEK_END) != 0)
+  {
+    return NULL;
+  }
+  size = ftell(file);
+  if(fseek(file, 0L, SEEK_SET) != 0)
+  {
+    return NULL;
+  }
+  buffer = (char *)xmalloc(size + 1);
+  if(buffer == NULL)
+  {
+    return NULL;
+  }
+  if(fread(buffer, 1, size, file) != (size_t)size)
+  {
+    return NULL;
+  }
+  fclose(file);
+  buffer[size] = '\0';
+  return buffer;
+}
