+  static const int order_0[] = {
+	7, 10, 5, 4, 3, 2, 1, 6, 11, 12, 9, 8, 13, 14, 15
+  };
+   /* Renesas order */
+   static const int order_1[] = {
+ 	14, 1, 2, 3, 4, 5, 6, 7, 10, 11, 8, 9, 12, 13, 15
