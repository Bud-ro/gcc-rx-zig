-.IX Item "file.go"
-Go source code.
-.IP "\fIfile\fR\fB.d\fR" 4
-.IX Item "file.d"
-D source code.
-.IP "\fIfile\fR\fB.di\fR" 4
-.IX Item "file.di"
-D interface file.
-.IP "\fIfile\fR\fB.dd\fR" 4
