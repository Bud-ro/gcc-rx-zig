-.IX Item "-mssse3"
-.IP "\fB\-msse4\fR" 4
-.IX Item "-msse4"
-.IP "\fB\-msse4a\fR" 4
-.IX Item "-msse4a"
-.IP "\fB\-msse4.1\fR" 4
-.IX Item "-msse4.1"
-.IP "\fB\-msse4.2\fR" 4
-.IX Item "-msse4.2"
-.IP "\fB\-mavx\fR" 4
-.IX Item "-mavx"
-.IP "\fB\-mavx2\fR" 4
-.IX Item "-mavx2"
-.IP "\fB\-mavx512f\fR" 4
-.IX Item "-mavx512f"
-.IP "\fB\-mavx512pf\fR" 4
-.IX Item "-mavx512pf"
-.IP "\fB\-mavx512er\fR" 4
-.IX Item "-mavx512er"
-.IP "\fB\-mavx512cd\fR" 4
-.IX Item "-mavx512cd"
-.IP "\fB\-mavx512vl\fR" 4
-.IX Item "-mavx512vl"
-.IP "\fB\-mavx512bw\fR" 4
-.IX Item "-mavx512bw"
-.IP "\fB\-mavx512dq\fR" 4
-.IX Item "-mavx512dq"
-.IP "\fB\-mavx512ifma\fR" 4
-.IX Item "-mavx512ifma"
-.IP "\fB\-mavx512vbmi\fR" 4
-.IX Item "-mavx512vbmi"
-.IP "\fB\-msha\fR" 4
-.IX Item "-msha"
-.IP "\fB\-maes\fR" 4
-.IX Item "-maes"
-.IP "\fB\-mpclmul\fR" 4
