-.ie n .IP """_\|_AVR_HAVE_8BIT_SP_\|_""" 4
-.el .IP "\f(CW_\|_AVR_HAVE_8BIT_SP_\|_\fR" 4
-.IX Item "__AVR_HAVE_8BIT_SP__"
